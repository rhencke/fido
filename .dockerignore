.git/
.gitignore

# Local build output + transient control/crash residue (never a build input)
/.fido/
**/*.fido-tmp-v1
/fido
*.test
*.out
vendor/
.env

# Rocq artifacts (reproducible from .v sources inside the image)
*.glob
*.vo
*.vok
*.vos
*.vio
.coq-native/

# Editor / OS noise
.DS_Store
*.swp
*.swo
