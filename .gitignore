# Go: every .go is generated, never checked in (the e2e smoke test's printed program); the uncommittable-Go
# seal + ocaml-origin gate are the backstops.
*.go
/fido
*.test
*.out
vendor/

# The e2e smoke test's generated OCaml (extraction output + the build-generated one-line writer) — never
# tracked; only the driver e2e/e2e.v is committed.
/e2e/e2e.ml
/e2e/e2e.mli
/e2e/gen_write.ml
/e2e/*.cmi
/e2e/*.cmo

# Environment
.env

