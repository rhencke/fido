(library
 (name rocq_go_extraction_plugin)
 (public_name rocq-go-extraction)
 (synopsis "Rocq → Go extraction plugin")
 (flags :standard -rectypes -open Extraction_plugin)
 (libraries
  rocq-runtime.plugins.extraction
  rocq-runtime.interp
  rocq-runtime.vernac))

(rule
 (targets g_go_extraction.ml)
 (deps    (:mlg g_go_extraction.mlg))
 (action  (chdir %{project_root} (run rocq pp-mlg %{deps}))))
