; The ONE handwritten OCaml boundary: the Fido Emit transport plugin.  The library bundles the generic
; dirty-directory filesystem sink (fido_sink.ml) and the transport decode + vernac (g_fido.mlg).  It
; decodes only the final (path, bytes) transport data; it walks no program/AST/proof.  The Fido Emit
; command is run EXPLICITLY (rocq c on the witness), never as a cached dune .vo side effect.
(library
 (name fido_emit)
 (public_name fido.emit)
 (flags (:standard -rectypes -w -a))
 (libraries rocq-runtime.vernac unix))

(rocq.pp (modules g_fido))
