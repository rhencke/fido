#!/bin/sh
# Keep the repository consistent with the PROOF, and seal generated Go as uncommittable.
#
# Fido is a proof repository under a foundation reset: there is NO handwritten OCaml, NO plugin, and NO
# emitted Go this round.  On any proof / build change we run the verify (make check) — the surviving Rocq
# must compile with zero axioms — so a broken proof or a reintroduced backend hallmark aborts the commit.
set -e

# (1) OCaml-origin gate: zero tracked OCaml (the backend is deleted; there is no emission glue this round).
sh tools/ocaml-origin-gate.sh

# (2) SEAL: no generated Go is tracked.  There is no emission now; if it returns, generated *.go stays
#     gitignored, and a tracked *.go (e.g. `git add -f`) could let stale bytes drift into source.
tracked_go=$(git ls-files -- '*.go')
if [ -n "$tracked_go" ]; then
  echo "fido: ERROR — a tracked *.go exists, but generated Go is never committed:"
  echo "$tracked_go" | sed 's/^/  /'
  exit 1
fi

# (3) Anti-axiom DECLARATION tripwire over ALL tracked .v.  This is DEFENSE-IN-DEPTH, not the authority: the
#     authority is Rocq's own `Print Assumptions`, asserted ZERO by `make check` (spine-gate).  This cheap
#     scan catches a casual Axiom/Parameter/Conjecture/Admitted, or a top-level Hypothesis/Variable in a
#     no-Section file, before commit.  Comments are stripped first, so prose may use these words freely.
strip_comments() {
  awk 'BEGIN{d=0} {
    n=length($0); out=""; i=1;
    while(i<=n){
      two=substr($0,i,2);
      if(two=="(*"){d++; out=out"  "; i+=2; continue}
      if(two=="*)"&&d>0){d--; out=out"  "; i+=2; continue}
      c=substr($0,i,1); if(d>0){out=out" "}else{out=out c}; i++;
    }
    print out;
  }' "$1"
}
cb='(^|[.][[:space:]])[[:space:]]*'
amod='((#\[[^]]*\]|Local|Global|Polymorphic|Monomorphic)[[:space:]]+)*'
scanned_v=$(git ls-files '*.v')
axiom_hit=""
for f in $scanned_v; do
  if strip_comments "$f" | grep -qE "${cb}${amod}(Axiom|Axioms|Parameter|Parameters|Conjecture)[[:space:]]|Admitted"; then
    axiom_hit="$f (Axiom/Parameter/Conjecture/Admitted)"; break
  fi
  # every spine file is Section-free by design → a top-level Hypothesis/Variable would be a global assumption
  if strip_comments "$f" | grep -qE "${cb}Section[[:space:]]"; then
    axiom_hit="$f (Section — the certified spine carries none; a Section-local Variable would need review)"; break
  fi
  if strip_comments "$f" | grep -qE "${cb}${amod}(Hypothesis|Hypotheses|Variable|Variables)[[:space:]]"; then
    axiom_hit="$f (top-level Hypothesis/Variable)"; break
  fi
done
if [ -n "$axiom_hit" ]; then
  echo "fido: ERROR — a Fido axiom-shaped declaration was introduced: $axiom_hit."
  echo "fido: the 0-axiom guarantee forbids this; model the construct as a Definition."
  exit 1
fi

# (4) On any proof / build change, run the certified verify so a broken proof / rejected Go aborts the commit.
if git diff --cached --name-only | grep -qE '\.v$|^tools/|^Makefile$|^Dockerfile$|^dune$|^dune-project$'; then
  echo "fido: proof/build input staged — running the certified verify (make check)..."
  make check
fi

echo "fido: certified — proof, bytes, and Go toolchain in sync."
