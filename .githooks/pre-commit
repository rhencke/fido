#!/bin/sh
# Keep the checked-in Go in sync with the prover.
#
# When any prover input (a .v theory or the extraction plugin) is staged, OR a
# generated .go is staged directly, re-extract and auto-stage the generated Go, so
# a commit can never drift out of sync with what Rocq produces.  This is also the
# anti-tampering gate: the committed *.go is ALWAYS overwritten by fresh prover
# output, so a hand-edit of *.go cannot survive a commit — INCLUDING a .go-ONLY edit
# with no .v/plugin change.  (The previous trigger matched only .v/plugin, so a staged
# hand-edited .go with no source change slipped through — a review #4 R10 hole.)
# Extraction failure (e.g. a broken proof) aborts the commit.
set -e

# Code-discipline gate (smart-ctor-gate.sh — the structural checks enumerated in that file): e.g. assert
# plugin/go.ml constructs the proof-carrying Printer atoms/types ONLY via the re-checking smart constructors
# (a direct GTNamed/EId would bypass the erased Rocq invariant).  Cheap static
# scan; the Docker prover stage runs it non-bypassably too, this is the fast local backstop.  (GoSem
# axiom-freedom is gated by Rocq's own Print Assumptions in the Docker manifest gate, not by this script.)
if git diff --cached --name-only | grep -qE '^plugin/'; then
  sh plugin/smart-ctor-gate.sh
fi

if git diff --cached --name-only | grep -qE '\.v$|^plugin/|\.go$'; then
  echo "fido: prover inputs (or a generated .go) staged — re-extracting and staging Go..."
  echo "fido: (.go is GENERATED from the .v; any hand-edit is reverted to prover output here)"
  # plugin/printer.ml is ITSELF a generated artifact — extracted from GoPrint.v by a
  # plugin-free `rocq c` step (it's the OCaml the plugin LINKS).  Treat it exactly like
  # the *.go below: when GoAst.v / GoPrint.v is staged, regenerate and stage it, so a
  # spine change can NEVER leave plugin/printer.ml stale — which the Docker drift gate inside
  # `make extract` (below) would otherwise reject, forcing a manual `make printer` re-do.
  # `make printer` also runs the zero-axiom gate, so a broken / axiom-bearing GoAst/GoPrint
  # aborts the commit right here (like a failed extraction).  Needs host rocq, as the
  # sibling local printer targets (printer / printer-verify) already do.
  if git diff --cached --name-only | grep -qE '(^|/)(GoAst|GoPrint)\.v$'; then
    echo "fido: GoAst.v/GoPrint.v staged — regenerating plugin/printer.ml (make printer)..."
    make printer
    git add -- plugin/printer.ml
  fi
  make extract
  git add -A -- '*.go'
  echo "fido: staged fresh extraction."
fi

# Generated Go must be gofmt-clean.  By design the plugin emits valid-but-not-
# canonical whitespace and `make extract` canonicalises it with `gofmt -w` (gofmt
# is Go's only definition of canonical surface form; we don't reimplement it).
# This check is a BACKSTOP: since `make extract` (above) just ran `gofmt -w`, it
# should always pass — a failure means the `gofmt -w` step didn't run, not that
# the plugin is wrong.  Use host gofmt if present, else the build's Go image — do
# NOT let a missing host gofmt silently skip it (that let bad output through once).
if ls ./*.go >/dev/null 2>&1; then
  if command -v gofmt >/dev/null 2>&1; then
    unformatted=$(gofmt -l ./*.go)
  else
    unformatted=$(docker run --rm -v "$(pwd)":/w -w /w "$(make -s print-goimage)" gofmt -l ./*.go 2>/dev/null)
  fi
  if [ -n "$unformatted" ]; then
    echo "fido: ERROR — generated Go is not gofmt-clean (did 'make extract' run gofmt -w?):"
    echo "$unformatted"
    exit 1
  fi
fi

# Anti-axiom gate.  The headline guarantee is ZERO Fido axioms.  The COMPLETE, declaration-form-immune check
# is Rocq's own `Print Assumptions` — captured non-bypassably by the Docker manifest gate, which reports an
# axiom no matter HOW it is declared (Local/Global/Polymorphic, attribute stacks, imported, transitive) or
# refuses the form (Private Axiom, top-level Context).  This grep is a cheap commit-time DECLARATION tripwire
# (review #3 R10 widened it from builtins.v/main.v to ALL theory files; it now also catches locality
# modifiers and attribute stacks before the keyword — the forms a bare-keyword scan missed).  It is NOT the
# authority and makes no completeness claim — a legal form it misses is caught by the Rocq manifest gate:
#  (a) Axiom / Parameter / Conjecture / Admitted are forbidden in EVERY tracked .v — the proof-only
#      theories (concurrency.v / unified.v), the spine (GoAst/GoPrint/GoTypes/GoSafe/GoEmit), the emit demo
#      (emitdemo/emit_demo.v) AND the fail-closed fixtures (negtests/*.v): an Admitted is an INCOMPLETE
#      proof and an Axiom/Parameter is a global assumption, neither of which the 0-axiom claim allows
#      ANYWHERE.  The scan set is DERIVED from `git ls-files '*.v'` (NOT a hand-maintained list), so any
#      new tracked .v is auto-included and omission drift is impossible — a hard-coded list had silently
#      skipped emitdemo/emit_demo.v and negtests/*.v.  (negtests/*.v are NEGATIVE fixtures that ABORT
#      extraction — ordinary programs hitting fail-closed sites, so they legitimately contain no
#      Axiom/Admitted; if a tracked .v needs a banned word only in PROSE, keep that prose clear of the
#      bare word — the "Admitted in a comment" gotcha — rather than narrowing this scan.)
#  (b) A top-level Hypothesis / Variable is forbidden in every NO-SECTION .v — the extracted/model
#      modules (the whole builtins split: GoNumeric/GoRuntimeTypes/GoEffects/…/GoSwitch/GoComplex,
#      the spine, cmd.v, main.v) use no Sections by design, so ANY Hypothesis/Variable there is a
#      top-level assumption.  The set is DERIVED (a .v containing no `Section` command), so a new
#      split module can never be silently skipped.  The proof-only theories (concurrency.v /
#      unified.v / cmd_unified.v) legitimately use SECTION-local Hypothesis / Variable (discharged
#      at Section close — NOT global axioms), and their `Section` lines exempt them here
#      (Print Assumptions would catch a mis-discharged one).
scanned_v=$(git ls-files '*.v')
# SELF-CHECK INVARIANT: the set about to be scanned MUST equal the full tracked-.v set (re-derived
# independently here).  Since `scanned_v` IS `git ls-files '*.v'` this holds by construction today; the
# check exists so a FUTURE edit that re-hard-codes a narrower list into `scanned_v` trips here and FAILS
# the commit — a skipped tracked theory/fixture can never pass silently again.
if [ "$(printf '%s\n' $scanned_v | LC_ALL=C sort)" != "$(git ls-files '*.v' | LC_ALL=C sort)" ]; then
  echo "fido: ERROR — anti-axiom scan set != git ls-files '*.v'; a tracked theory/fixture would be skipped."
  echo "fido: the scan list must be DERIVED from 'git ls-files' so no .v is ever omitted."
  exit 1
fi
amod='((#\[[^]]*\]|Local|Global|Polymorphic|Monomorphic)[[:space:]]+)*'   # optional locality/attribute prefix
if grep -nE "^[[:space:]]*${amod}(Axiom|Axioms|Parameter|Parameters|Conjecture)[[:space:]]|Admitted" \
        $scanned_v 2>/dev/null \
   || { nosec_v=$(for f in $scanned_v; do grep -qE '^[[:space:]]*Section[[:space:]]' "$f" || printf '%s\n' "$f"; done);
        [ -n "$nosec_v" ] && grep -nE "^[[:space:]]*${amod}(Hypothesis|Hypotheses|Variable|Variables)[[:space:]]" $nosec_v 2>/dev/null; }; then
  echo "fido: ERROR — a Fido Axiom/Parameter/Conjecture/Admitted (any tracked .v), or a top-level"
  echo "fido: Hypothesis/Variable in an extracted file, was introduced.  The 0-axiom guarantee forbids"
  echo "fido: this; model the construct as a Definition (or a discharged Section variable in a proof file)."
  exit 1
fi

echo "fido: Go in sync."
