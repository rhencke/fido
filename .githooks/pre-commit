#!/bin/sh
# Pre-commit — verify the PROPOSED COMMIT (the Git index), never the unstaged working tree, and never
# auto-stage or mutate the working tree.  Generated Go is a TRACKED, reviewed artifact of ONE certified
# generation; this hook proves the staged proof/generation inputs still build (proof gate + whole-tree go
# build) and that the STAGED root go.mod + recursive .go byte-match the pristine `generated-module` built
# from the staged inputs (exact path set + bytes).  This is a PROTOTYPE-stage boundary: `git commit
# --no-verify` bypasses it (a future PR CI runs the same staged/generated comparison server-side).
set -e

# (1) fast, INDEX-AUTHORITATIVE structural gates (transport-only OCaml; the generated-output policy reads
#     staged blobs via git, so it inspects the proposed commit's bytes, not the working tree).
sh tools/ocaml-origin-gate.sh
sh tools/generated-output-gate.sh

# (2) run the pinned Buildx verification only when the proposed commit touches proof / generation / build
#     inputs OR the tracked generated outputs.
if git diff --cached --quiet -- '*.v' '*.ml' '*.mlg' 'plugin/' 'e2e/' 'gate/' 'tools/' Makefile Dockerfile dune dune-project '*.go' go.mod .gitignore .dockerignore; then
  echo "fido: pre-commit gates OK — no proof/build/generated inputs staged (bypass with --no-verify)."
  exit 0
fi

command -v docker >/dev/null 2>&1 || { echo "fido: pre-commit needs docker for the pinned staged-index verification"; exit 1; }
docker buildx inspect fido-builder >/dev/null 2>&1 || docker buildx create --name fido-builder --driver docker-container --bootstrap >/dev/null

# (3) export the Git INDEX exactly once and use THAT staged tree as the entire Buildx context — so the proof
#     gate and the whole-tree go build run against the proposed commit.
tmp=$(mktemp -d); trap 'rm -rf "$tmp"' EXIT
git checkout-index --all --prefix="$tmp/context/"
echo "fido: pre-commit — verifying the STAGED tree (complete proof gate, whole-tree go build, staged==pristine generated bytes)..."
( cd "$tmp/context"
  docker buildx build --builder fido-builder --platform linux/amd64 --target prover .
  docker buildx build --builder fido-builder --platform linux/amd64 --target go-e2e . )

# (4) materialize the PRISTINE canonical module (built from the STAGED inputs) and byte-compare it against the
#     STAGED go.mod + recursive .go read from the Git index (see tools/staged-generated-compare.sh — immune to
#     .dockerignore/file-type filtering, never the unstaged working tree, both directions).
docker buildx build --builder fido-builder --platform linux/amd64 --target generated-artifact \
  --output "type=local,dest=$tmp/pristine" "$tmp/context"
sh tools/staged-generated-compare.sh "$tmp/pristine"

echo "fido: pre-commit OK — staged proof gate + whole-tree go build + staged-generated byte-equality all passed (bypass with --no-verify — a documented prototype-stage escape)."
