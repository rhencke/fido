#!/bin/sh
# Keep the repository consistent with the PROOF, and seal generated Go as uncommittable.
#
# Fido's vertical slice is proved AND executed.  On any proof / build change we run the verify (make check):
# the pinned-Rocq core must compile with its declared Print-Assumptions surfaces axiom-free, and the pinned-Go
# e2e must emit + build + run the witness against the goldens — so a broken proof, a reintroduced backend
# hallmark, or a broken emission aborts the commit.
set -e

# (1) OCaml-origin gate: at most the ONE tiny transport glue (plugin/g_fido.mlg) is tracked OCaml.
sh tools/ocaml-origin-gate.sh

# (2) SEAL: no generated Go is tracked.  The emitted main.go is produced in the build and stays gitignored;
#     a tracked *.go (e.g. `git add -f`) could let stale bytes drift into source.
tracked_go=$(git ls-files -- '*.go')
if [ -n "$tracked_go" ]; then
  echo "fido: ERROR — a tracked *.go exists, but generated Go is never committed:"
  echo "$tracked_go" | sed 's/^/  /'
  exit 1
fi

# (3) Anti-axiom DECLARATION tripwire over ALL tracked .v.  This is DEFENSE-IN-DEPTH, not the authority: the
#     authority is Rocq's own `Print Assumptions`, asserted by `make check` (gate/axiom_gate.v — compiled
#     fresh every build, count-checked so a warm cache cannot skip it).  This cheap
#     scan catches a casual Axiom/Parameter/Conjecture/Admitted, or a top-level Hypothesis/Variable in a
#     no-Section file, before commit.  Comments are stripped first, so prose may use these words freely.
strip_comments() {
  awk 'BEGIN{d=0} {
    n=length($0); out=""; i=1;
    while(i<=n){
      two=substr($0,i,2);
      if(two=="(*"){d++; out=out"  "; i+=2; continue}
      if(two=="*)"&&d>0){d--; out=out"  "; i+=2; continue}
      c=substr($0,i,1); if(d>0){out=out" "}else{out=out c}; i++;
    }
    print out;
  }' "$1"
}
cb='(^|[.][[:space:]])[[:space:]]*'
amod='((#\[[^]]*\]|Local|Global|Polymorphic|Monomorphic)[[:space:]]+)*'
scanned_v=$(git ls-files '*.v')
axiom_hit=""
for f in $scanned_v; do
  if strip_comments "$f" | grep -qE "${cb}${amod}(Axiom|Axioms|Parameter|Parameters|Conjecture)[[:space:]]|Admitted"; then
    axiom_hit="$f (Axiom/Parameter/Conjecture/Admitted)"; break
  fi
  # every surviving module is Section-free by design → a top-level Hypothesis/Variable would be a global assumption
  if strip_comments "$f" | grep -qE "${cb}Section[[:space:]]"; then
    axiom_hit="$f (Section — the surviving modules carry none; a Section-local Variable would need review)"; break
  fi
  if strip_comments "$f" | grep -qE "${cb}${amod}(Hypothesis|Hypotheses|Variable|Variables)[[:space:]]"; then
    axiom_hit="$f (top-level Hypothesis/Variable)"; break
  fi
done
if [ -n "$axiom_hit" ]; then
  echo "fido: ERROR — a Fido axiom-shaped declaration was introduced: $axiom_hit."
  echo "fido: the 0-axiom guarantee forbids this; model the construct as a Definition."
  exit 1
fi

# (4) On any proof / build / plugin / e2e change, run the verify so a broken proof, a reintroduced backend
#     hallmark, or a broken emission aborts the commit.
if git diff --cached --name-only | grep -qE '\.v$|\.mlg$|^tools/|^plugin/|^e2e/|^Makefile$|^Dockerfile$|^dune$|^dune-project$'; then
  echo "fido: proof/build/e2e input staged — running the verify (make check)..."
  make check
fi

echo "fido: OK — pinned-Rocq core compiles axiom-free, the e2e witness emits+builds+runs vs goldens, at most one glue."
