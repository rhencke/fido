#!/bin/sh
# Keep the checked-in Go in sync with the prover.
#
# When any prover input (a .v theory or the extraction plugin) is staged,
# re-extract and auto-stage the generated Go, so a commit can never drift out
# of sync with what Rocq produces.  This is also the anti-tampering gate: the
# committed *.go is always overwritten by fresh prover output, so a hand-edit
# of *.go cannot survive a commit.  Extraction failure (e.g. a broken proof)
# aborts the commit.
set -e

if git diff --cached --name-only | grep -qE '\.v$|^plugin/'; then
  echo "fido: prover inputs changed — re-extracting and staging Go..."
  make extract
  git add -A -- '*.go'
  echo "fido: staged fresh extraction."
fi

# Generated Go must be gofmt-clean.  By design the plugin emits valid-but-not-
# canonical whitespace and `make extract` canonicalises it with `gofmt -w` (gofmt
# is Go's only definition of canonical surface form; we don't reimplement it).
# This check is a BACKSTOP: since `make extract` (above) just ran `gofmt -w`, it
# should always pass — a failure means the `gofmt -w` step didn't run, not that
# the plugin is wrong.  Use host gofmt if present, else the build's Go image — do
# NOT let a missing host gofmt silently skip it (that let bad output through once).
if ls ./*.go >/dev/null 2>&1; then
  if command -v gofmt >/dev/null 2>&1; then
    unformatted=$(gofmt -l ./*.go)
  else
    unformatted=$(docker run --rm -v "$(pwd)":/w -w /w golang:1.23-alpine gofmt -l ./*.go 2>/dev/null)
  fi
  if [ -n "$unformatted" ]; then
    echo "fido: ERROR — generated Go is not gofmt-clean (did 'make extract' run gofmt -w?):"
    echo "$unformatted"
    exit 1
  fi
fi

# Anti-axiom gate.  The headline guarantee is ZERO Fido axioms: the emitted-Go layer
# (builtins.v) and the extraction driver (main.v) must rest only on Rocq's own machine
# primitives (verified by `Print Assumptions main_effect` = int/float + PrimInt63/PrimFloat
# ops).  Fail loud if a global Axiom/Parameter/Conjecture or an Admitted creeps in.
# (concurrency.v is proof-only theory and may use parameterised SECTION hypotheses; it is
# not part of any extracted program's trust base, so it is excluded here.)
if grep -nE '^[[:space:]]*(Axiom|Parameter|Conjecture|Hypothesis)[[:space:]]|Admitted' builtins.v main.v 2>/dev/null; then
  echo "fido: ERROR — a Fido axiom / Admitted was introduced in builtins.v or main.v."
  echo "fido: the 0-axiom guarantee forbids this; model the construct as a Definition instead."
  exit 1
fi

echo "fido: Go in sync."
