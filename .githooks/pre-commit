#!/bin/sh
# Pre-commit — verify the PROPOSED COMMIT (the Git index) and nothing else.  It exports the index EXACTLY
# ONCE and, from that point on, treats the exported staged snapshot as the AUTHORITATIVE source tree for
# every gate implementation AND every source byte — so a staged bad gate script or staged bad OCaml boundary
# is the version evaluated, not the (possibly safe) working-tree copy.  It runs on EVERY ordinary commit
# (no conditional "relevant input" list; Buildx caching is the only optimization), and it never mutates the
# working tree, alters the index, or runs `git add`.  PROTOTYPE boundary: `git commit --no-verify` bypasses
# it (a future PR CI runs the same staged/generated comparison server-side); do not remove that honest limit.
set -e

command -v docker >/dev/null 2>&1 || { echo "fido: pre-commit needs docker for the pinned staged-index verification"; exit 1; }
docker buildx inspect fido-builder >/dev/null 2>&1 || docker buildx create --name fido-builder --driver docker-container --bootstrap >/dev/null

# (1) export the Git INDEX exactly once into a temp dir; this exported tree is the proposed commit and needs
#     no .git to inspect source contents.
tmp=$(mktemp -d); trap 'rm -rf "$tmp"' EXIT
ctx="$tmp/context"
git checkout-index --all --prefix="$ctx/"

# (2) run the STAGED COPIES of the structural gates on the exported staged tree (never the working-tree copies).
sh "$ctx/tools/ocaml-origin-gate.sh"    "$ctx"
sh "$ctx/tools/generated-output-gate.sh" "$ctx"

# (3) full cached verification on EVERY ordinary commit: the complete proof gate + the whole-tree Go e2e,
#     built from the exported staged context (Buildx caching is the optimization).
echo "fido: pre-commit — verifying the STAGED tree (complete proof gate, whole-tree go build, staged==pristine generated bytes)..."
( cd "$ctx"
  docker buildx build --builder fido-builder --platform linux/amd64 --target prover .
  docker buildx build --builder fido-builder --platform linux/amd64 --target go-e2e . )

# (4) materialize the PRISTINE generated-module (derived by Buildx from the STAGED inputs only — .dockerignore
#     excludes the committed generated bytes) and byte-compare it against the STAGED generated go.mod +
#     recursive .go, via the STAGED comparison script over the exported tree (path set + bytes, both
#     directions, exact regular-file/mode already enforced by the generated-output gate above).
docker buildx build --builder fido-builder --platform linux/amd64 --target generated-artifact \
  --output "type=local,dest=$tmp/pristine" "$ctx"
sh "$ctx/tools/staged-generated-compare.sh" "$ctx" "$tmp/pristine"

echo "fido: pre-commit OK — the entire verification (staged gates + proof gate + whole-tree go build + staged==pristine generated bytes) ran against the exported Git index (bypass with --no-verify — a documented prototype-stage escape)."
